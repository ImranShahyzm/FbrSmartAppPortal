# Copy to `.env.production` in this folder before `npm run build` in FbrAdminPortal.
# Use the SAME `VITE_API_BASE_URL` as the main application if both UIs talk to the same API.
#
# Single-site deploy (admin portal static files served from the same host as the API, paths /api + /uploads):
#   Leave empty → browser calls `/api/...` on the current origin.
# VITE_API_BASE_URL=
#
# Split deploy (admin UI on another origin, API elsewhere):
# VITE_API_BASE_URL=https://api.yourcompany.com

VITE_API_BASE_URL=
