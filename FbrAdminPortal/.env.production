# FBR Admin Portal — production build (Vite bakes this in at `npm run build`).
# Set this to the same published API base URL as the main app’s `.env.production`, or leave empty if the
# admin UI is served from the same site as the API (requests use `/api` on the current host).

VITE_API_BASE_URL=https://fbrsmartapi.corbissoft.com

