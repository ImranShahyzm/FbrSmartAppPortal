        public ApiResponse ValidateInvoice(Fbr_DigitalInvoicing objInvoice, string token)
        {
            using (var client = new HttpClient(new HttpClientHandler { AutomaticDecompression = DecompressionMethods.GZip | DecompressionMethods.Deflate }))
            {
                // Configure headers to match FBR portal
                client.DefaultRequestHeaders.Authorization = new AuthenticationHeaderValue("Bearer", token);
                client.DefaultRequestHeaders.Accept.Add(new MediaTypeWithQualityHeaderValue("application/json"));
                client.DefaultRequestHeaders.UserAgent.ParseAdd("Postman.Now/1.0"); // Match Postman-like behavior
                client.Timeout = TimeSpan.FromSeconds(30);

                // Serialize payload
                string jsonPayload = JsonConvert.SerializeObject(objInvoice, Formatting.Indented);
                Console.WriteLine("📤 Serialized JSON Payload:");
                Console.WriteLine(jsonPayload);

                var content = new StringContent(jsonPayload, Encoding.UTF8, "application/json");

                // Configure SSL/TLS
                ServicePointManager.SecurityProtocol = SecurityProtocolType.Tls12; // Include Tls13
                                                                                   // For dev only: bypass SSL/TLS validation (remove in production)
                ServicePointManager.ServerCertificateValidationCallback += (sender, cert, chain, sslPolicyErrors) => true;

                HttpResponseMessage response = null;
                string result = string.Empty;

                try
                {
                    // Send request
                    response = client.PostAsync("https://gw.fbr.gov.pk/di_data/v1/di/validateinvoicedata_sb", content).GetAwaiter().GetResult();
                    Console.WriteLine($"✅ HTTP Status: {response.StatusCode}");
                    Console.WriteLine($"📋 Content-Length: {response.Content.Headers.ContentLength ?? -1}");

                    // Log headers
                    Console.WriteLine("📋 Response Headers:");
                    foreach (var header in response.Headers)
                    {
                        Console.WriteLine($"{header.Key}: {string.Join(", ", header.Value)}");
                    }

                    // Check status code
                    if (!response.IsSuccessStatusCode)
                    {
                        result = response.Content.ReadAsStringAsync().GetAwaiter().GetResult();
                        Console.WriteLine($"❌ Error Response: {result}");
                        return new ApiResponse
                        {
                            validationResponse = new ValidationResponse
                            {
                                statusCode = "98",
                                status = "Failed",
                                error = $"HTTP request failed with status: {response.StatusCode}, Response: {result}"
                            }
                        };
                    }

                    // Buffer response content
                    response.Content.LoadIntoBufferAsync().GetAwaiter().GetResult();

                    // Read response content
                    result = response.Content.ReadAsStringAsync().GetAwaiter().GetResult();
                    Console.WriteLine("📥 Raw Response:");
                    Console.WriteLine("-----------------------------------");
                    Console.WriteLine(result);

                    // Fallback: Read stream directly if empty
                    if (string.IsNullOrWhiteSpace(result))
                    {
                        Console.WriteLine("⚠️ Empty response from ReadAsStringAsync, trying fallback stream read");
                        using (var stream = response.Content.ReadAsStreamAsync().GetAwaiter().GetResult())
                        using (var reader = new StreamReader(stream, Encoding.UTF8))
                        {
                            result = reader.ReadToEnd();
                            Console.WriteLine("📥 Fallback Stream Response:");
                            Console.WriteLine(result);
                        }
                    }

                    // Check for empty response
                    if (string.IsNullOrWhiteSpace(result))
                    {
                        Console.WriteLine("❌ Empty response received");
                        return new ApiResponse
                        {
                            validationResponse = new ValidationResponse
                            {
                                statusCode = "99",
                                status = "Failed",
                                error = "API returned an empty response despite successful request"
                            }
                        };
                    }

                    // Check for non-JSON response
                    if (!result.TrimStart().StartsWith("{") && !result.TrimStart().StartsWith("["))
                    {
                        Console.WriteLine("❌ Non-JSON response received:");
                        Console.WriteLine(result);
                        return new ApiResponse
                        {
                            validationResponse = new ValidationResponse
                            {
                                statusCode = "96",
                                status = "Failed",
                                error = "Non-JSON response received from FBR API"
                            }
                        };
                    }

                    // Deserialize response
                    var settings = new JsonSerializerSettings
                    {
                        MissingMemberHandling = MissingMemberHandling.Ignore,
                        NullValueHandling = NullValueHandling.Include,
                        ContractResolver = new DefaultContractResolver
                        {
                            NamingStrategy = new CamelCaseNamingStrategy()
                        },
                        Error = (sender, args) =>
                        {
                            Console.WriteLine($"⚠️ JSON Warning: {args.ErrorContext.Error.Message}");
                            args.ErrorContext.Handled = true;
                        }
                    };

                    var apiResponse = JsonConvert.DeserializeObject<ApiResponse>(result, settings);
                    if (apiResponse == null)
                    {
                        Console.WriteLine("❌ Deserialization returned null");
                        return new ApiResponse
                        {
                            validationResponse = new ValidationResponse
                            {
                                statusCode = "94",
                                status = "Failed",
                                error = "Deserialization returned null API response"
                            }
                        };
                    }

                    if (apiResponse.validationResponse == null)
                    {
                        Console.WriteLine("❌ validationResponse is missing");
                        apiResponse.validationResponse = new ValidationResponse
                        {
                            statusCode = "94",
                            status = "Failed",
                            error = "validationResponse is missing in the API response"
                        };
                    }

                    var vr = apiResponse.validationResponse;

                    if (vr.statusCode == "00")
                    {
                        Console.WriteLine("✅ Invoice posted successfully.");
                        Console.WriteLine($"🧾 Invoice Number: {apiResponse.invoiceNumber}");
                        foreach (var item in vr.invoiceStatuses ?? new List<InvoiceStatus>())
                        {
                            Console.WriteLine($"  - Item {item.itemSNo}: Status={item.status}, InvoiceNo={item.invoiceNo}");
                        }
                    }
                    else
                    {
                        Console.WriteLine("❌ Invoice validation failed.");
                        if (!string.IsNullOrEmpty(vr.error))
                            Console.WriteLine($"Top-Level Error: {vr.error}");
                        foreach (var item in vr.invoiceStatuses ?? new List<InvoiceStatus>())
                        {
                            Console.WriteLine($"  - Item {item.itemSNo}: Error={item.error}, Code={item.errorCode}");
                        }
                    }

                    return apiResponse;
                }
                catch (HttpRequestException ex)
                {
                    Console.WriteLine($"❌ HTTP POST failed: {ex.Message}");
                    return new ApiResponse
                    {
                        validationResponse = new ValidationResponse
                        {
                            statusCode = "98",
                            status = "Failed",
                            error = $"HTTP POST exception: {ex.Message}"
                        }
                    };
                }
                catch (Exception ex)
                {
                    Console.WriteLine($"❌ Unexpected error: {ex.Message}");
                    return new ApiResponse
                    {
                        validationResponse = new ValidationResponse
                        {
                            statusCode = "97",
                            status = "Failed",
                            error = $"Unexpected error: {ex.Message}"
                        }
                    };
                }
                finally
                {
                    response?.Dispose();
                }
            }
        }

