        private DataTable CheckExistingInvoices(DataTable tvp)
        {
            Connection cs = new Connection();
            DataTable existingInvoices = new DataTable();

            using (SqlConnection conn = new SqlConnection(cs.GetConnectionString()))
            using (SqlCommand cmd = new SqlCommand("CheckFbrInvoicesExistence", conn))
            {
                cmd.CommandType = CommandType.StoredProcedure;

                SqlParameter tvpParam = cmd.Parameters.AddWithValue("@InvoiceData", tvp);
                tvpParam.SqlDbType = SqlDbType.Structured;
                tvpParam.TypeName = "FbrInvoicesType";

                using (SqlDataAdapter da = new SqlDataAdapter(cmd))
                {
                    da.Fill(existingInvoices);
                }
            }

            return existingInvoices;
        }


