        private int? SafeInt(object value, string columnName, int rowIndex)
        {
            if (value == null || value == DBNull.Value || string.IsNullOrWhiteSpace(value.ToString()))
                return null;
            if (int.TryParse(value.ToString(), out int result))
                return result;
            MessageBox.Show($"Invalid integer in column '{columnName}' at row {rowIndex + 1}: '{value}'");
            return null;
        }

        private decimal? SafeDecimal(object value, string columnName, int rowIndex)
        {
            if (value == null || value == DBNull.Value || string.IsNullOrWhiteSpace(value.ToString()))
                return null;
            if (decimal.TryParse(value.ToString(), out decimal result))
                return result;
            MessageBox.Show($"Invalid decimal in column '{columnName}' at row {rowIndex + 1}: '{value}'");
            return null;
        }

        private DateTime? SafeDate(object value, string columnName, int rowIndex)
        {
            if (value == null || value == DBNull.Value || string.IsNullOrWhiteSpace(value.ToString()))
                return null;
            if (DateTime.TryParse(value.ToString(), out DateTime result))
                return result;
            MessageBox.Show($"Invalid date in column '{columnName}' at row {rowIndex + 1}: '{value}'");
            return null;
        }


        private async void btnSubmit_Click(object sender, EventArgs e)
        {
            btnSubmit.Enabled = false;
            progressBar1.Visible = true;
            lblProgress.Visible = true;
            progressBar1.Value = 0;

            if(CheckBeforeSubmission())
            {
                btnSubmit.Enabled = true;
                return;
            }

            try
            {
                var result = FbrLibraryClasses.ConvertGridToFbrInvoices(this.FrbInvGrid);
                int total = result.Count;

                if (total == 0)
                {
                    MessageBox.Show("No invoices found to submit.");
                    return;
                }
                if (!FrbInvGrid.Columns.Contains("FBRInvoiceNumber"))
                {
                    FrbInvGrid.Columns.Add("FBRInvoiceNumber", "FBR Invoice Number");
                }
              
                progressBar1.Maximum = total;

                await Task.Run(() =>
                {
                    var obj = new Fbr_DigitalInvoicing();
                    int current = 0;

                    for (int i = 0; i < result.Count; i++)
                    {
                        var data = result[i];
                        bool alreadySent = FrbInvGrid.Rows
        .Cast<DataGridViewRow>()
        .Any(r =>
            r.Cells["UniqueInvoiceID"].Value?.ToString() == data.UniqueInvoiceID &&
            r.Cells["FbrInvoiceNumber"] != null &&
            r.Cells["FbrInvoiceNumber"].Value != null &&
            !string.IsNullOrWhiteSpace(r.Cells["FbrInvoiceNumber"].Value.ToString())
        );

                        if (alreadySent)
                            continue;

                      
                        ApiResponse response = null;

                        try
                        {
                            bool isRunningInVisualStudio = Debugger.IsAttached;
                            if (LoginInfo.EnableSandBox && !isRunningInVisualStudio)
                            {
                                response = obj.SendModelToApi(data, LoginInfo.FbrTokenProduction,false,true);
                            }
                            else
                            {
                                response = obj.SendModelToApi(data, LoginInfo.FbrTokenSandBox);
                            }

                            Invoke(new Action(() =>
                            {
                                if (response != null && response.validationResponse?.statusCode == "00")
                                {
                                    // If column doesn't exist, create it (once)
                                    if (!FrbInvGrid.Columns.Contains("FbrInvoiceNumber"))
                                    {
                                        FrbInvGrid.Columns.Add("FbrInvoiceNumber", "FBR Invoice #");
                                    }

                                    string fbrNo = response.invoiceNumber ?? "";
                                    string uniqueId = data.UniqueInvoiceID; 

                                    // ✅ Update all rows with same UniqueInvoiceID
                                    foreach (DataGridViewRow r in FrbInvGrid.Rows)
                                    {
                                        if (r.Cells["UniqueInvoiceID"].Value?.ToString() == uniqueId)
                                        {
                                            r.Cells["FbrInvoiceNumber"].Value = fbrNo;
                                            r.DefaultCellStyle.BackColor = Color.LightGreen;
                                        }
                                    }
                                }
                                else
                                {
                                    string uniqueId = data.UniqueInvoiceID;

                                    // ✅ Update all rows with same UniqueInvoiceID
                                    foreach (DataGridViewRow r in FrbInvGrid.Rows)
                                    {
                                        if (r.Cells["UniqueInvoiceID"].Value?.ToString() == uniqueId)
                                        {
                                            r.DefaultCellStyle.BackColor = Color.OrangeRed;
                                        }
                                      
                                      
                                    }

                                    string err = response?.validationResponse?.error ?? "Unknown error";
                                    // ❌ Stop processing here
                                    MessageBox.Show($"Invoice submission failed:\n{err}", "API Submission Failed", MessageBoxButtons.OK, MessageBoxIcon.Error);
                                    throw new Exception(err); // break outer loop
                                }

                                progressBar1.Value = ++current;
                            }));
                        }
                        catch (Exception ex)
                        {
                            Invoke(new Action(() =>
                            {
                                MessageBox.Show($"Error in invoice:\n{ex.Message}", "Error", MessageBoxButtons.OK, MessageBoxIcon.Error);
                                progressBar1.Value = ++current;
                            }));
                            break; // ❌ stop loop on error
                        }
                    }
                });

                MessageBox.Show("Invoice submission process completed.");
                btnExportExcel.Visible = true;
            }
            catch (Exception ex)
            {
                MessageBox.Show($"An error occurred: {ex.Message}", "Submission Failed", MessageBoxButtons.OK, MessageBoxIcon.Error);
            }
            finally
            {
                progressBar1.Visible = false;
                lblProgress.Visible = false;
                btnSubmit.Enabled = true;
            }
        }


        private void btnExportExcel_Click(object sender, EventArgs e)
    {
        try
        {
            if (FrbInvGrid.Rows.Count == 0)
            {
                MessageBox.Show("There is no data to export.", "Export Error", MessageBoxButtons.OK, MessageBoxIcon.Warning);
                return;
            }

            using (SaveFileDialog sfd = new SaveFileDialog())
            {
                sfd.Filter = "Excel Workbook|*.xlsx";
                sfd.FileName = "FBRInvoicesExport.xlsx";

                if (sfd.ShowDialog() == DialogResult.OK)
                {
                    using (var workbook = new XLWorkbook())
                    {
                        var worksheet = workbook.Worksheets.Add("FBR Invoices");

                        // Add headers
                        for (int col = 0; col < FrbInvGrid.Columns.Count; col++)
                        {
                            worksheet.Cell(1, col + 1).Value = FrbInvGrid.Columns[col].HeaderText;
                            worksheet.Cell(1, col + 1).Style.Font.Bold = true;
                        }

                        // Add data
                        for (int row = 0; row < FrbInvGrid.Rows.Count; row++)
                        {
                            for (int col = 0; col < FrbInvGrid.Columns.Count; col++)
                            {
                                object value = FrbInvGrid.Rows[row].Cells[col].Value;
                                worksheet.Cell(row + 2, col + 1).Value = value?.ToString();
                            }
                        }

                        workbook.SaveAs(sfd.FileName);
                        MessageBox.Show("Data exported successfully to Excel.", "Success", MessageBoxButtons.OK, MessageBoxIcon.Information);
                    }
                }
            }
        }
        catch (Exception ex)
        {
            MessageBox.Show("Export failed:\n" + ex.Message, "Error", MessageBoxButtons.OK, MessageBoxIcon.Error);
        }
