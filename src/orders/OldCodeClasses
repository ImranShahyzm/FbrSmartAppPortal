        private void btnUploadExcel_Click(object sender, EventArgs e)
        {
            try
            {
                using (OpenFileDialog openFileDialog = new OpenFileDialog())
                {
                    openFileDialog.Filter = "Excel Files|*.xls;*.xlsx";
                    if (openFileDialog.ShowDialog() == DialogResult.OK)
                    {
                        using (var stream = File.Open(openFileDialog.FileName, FileMode.Open, FileAccess.Read))
                        {
                            using (var reader = ExcelReaderFactory.CreateReader(stream))
                            {
                                var result = reader.AsDataSet(new ExcelDataSetConfiguration()
                                {
                                    ConfigureDataTable = (_) => new ExcelDataTableConfiguration()
                                    {
                                        UseHeaderRow = true
                                    }
                                });

                                if (result.Tables.Count == 0)
                                {
                                    MessageBox.Show("The selected Excel file does not contain any sheets.", "Empty File", MessageBoxButtons.OK, MessageBoxIcon.Warning);
                                    return;
                                }

                                DataTable table = result.Tables[0];

                                if (table.Rows.Count == 0)
                                {
                                    MessageBox.Show("The selected Excel sheet is empty.", "No Data", MessageBoxButtons.OK, MessageBoxIcon.Information);
                                    return;
                                }

                                // Bind to grid
                                FrbInvGrid.DataSource = table;

                                // ✅ Add "Valid" checkbox column if not already added
                                if (!FrbInvGrid.Columns.Contains("Valid"))
                                {
                                    DataGridViewCheckBoxColumn validCol = new DataGridViewCheckBoxColumn
                                    {
                                        Name = "Valid",
                                        HeaderText = "Valid",
                                        ReadOnly = true
                                    };
                                    FrbInvGrid.Columns.Add(validCol);
                                }

                                MessageBox.Show("Excel data loaded successfully.", "Success", MessageBoxButtons.OK, MessageBoxIcon.Information);
                            }
                        }
                    }
                }
            }
            catch (IOException ioEx)
            {
                MessageBox.Show("File access error: " + ioEx.Message, "IO Error", MessageBoxButtons.OK, MessageBoxIcon.Error);
            }
            catch (HeaderException hex)
            {
                MessageBox.Show("Excel format error: " + hex.Message, "Format Error", MessageBoxButtons.OK, MessageBoxIcon.Error);
            }
            catch (Exception ex)
            {
                MessageBox.Show("An unexpected error occurred:\n" + ex.Message, "Error", MessageBoxButtons.OK, MessageBoxIcon.Error);
            }
        }

        private async void btnValidate_Click(object sender, EventArgs e)
        {
            if (!FrbInvGrid.Columns.Contains("FBRInvoiceNumber"))
            {
                FrbInvGrid.Columns.Add("FBRInvoiceNumber", "FBR Invoice Number");
            }

            for (int i = 0; i < FrbInvGrid.Rows.Count; i++)
            {
                var row = FrbInvGrid.Rows[i];
                if (row.IsNewRow) continue;

                bool isValid = true;
                string errorMessage = "";

                var sellerNTN = Convert.ToString(row.Cells["sellerNTNCNIC"].Value);
                var sellerAddress = Convert.ToString(row.Cells["sellerAddress"].Value);
                var buyerNTN = Convert.ToString(row.Cells["buyerNTNCNIC"].Value);
                var buyerAddress = Convert.ToString(row.Cells["buyerAddress"].Value);
                var hsCode = Convert.ToString(row.Cells["hsCode"].Value);
                var totalValues = Convert.ToString(row.Cells["totalValues"].Value);

                if (string.IsNullOrWhiteSpace(sellerNTN)) { isValid = false; errorMessage += "Seller NTN is required.\n"; }
                if (string.IsNullOrWhiteSpace(sellerAddress)) { isValid = false; errorMessage += "Seller Address is required.\n"; }
                if (string.IsNullOrWhiteSpace(buyerNTN)) { isValid = false; errorMessage += "Buyer NTN is required.\n"; }
                if (string.IsNullOrWhiteSpace(buyerAddress)) { isValid = false; errorMessage += "Buyer Address is required.\n"; }
                if (string.IsNullOrWhiteSpace(hsCode)) { isValid = false; errorMessage += "HS Code is required.\n"; }
                if (!decimal.TryParse(totalValues, out _)) { isValid = false; errorMessage += "Total value must be numeric.\n"; }

                if (!isValid)
                {
                    row.DefaultCellStyle.BackColor = Color.Red;
                    row.Cells["Valid"].Value = false;
                    MessageBox.Show($"Validation failed for Row {i + 1}:\n\n{errorMessage}", "Validation Error", MessageBoxButtons.OK, MessageBoxIcon.Warning);
                    FrbInvGrid.CurrentCell = row.Cells[0];
                    return;
                }

                row.DefaultCellStyle.BackColor = Color.White;
                row.Cells["Valid"].Value = true;

                // ✅ Prepare temp DataGridView with this single row
                var tempGrid = new DataGridView();
                foreach (DataGridViewColumn col in FrbInvGrid.Columns)
                {
                    tempGrid.Columns.Add((DataGridViewColumn)col.Clone());
                }

                var tempRowIndex = tempGrid.Rows.Add();
                for (int colIndex = 0; colIndex < FrbInvGrid.Columns.Count; colIndex++)
                {
                    tempGrid.Rows[tempRowIndex].Cells[colIndex].Value = row.Cells[colIndex].Value;
                }

                // 🧠 Call the same method but only on this tempGrid
                var singleRowModels = FbrLibraryClasses.ConvertGridToFbrInvoices(tempGrid);
                if (singleRowModels == null || singleRowModels.Count == 0)
                {
                    row.DefaultCellStyle.BackColor = Color.OrangeRed;
                    MessageBox.Show($"Failed to convert Row {i + 1} to FBR model.", "Conversion Error", MessageBoxButtons.OK, MessageBoxIcon.Error);
                    return;
                }

                var invoiceModel = singleRowModels[0];
                var api = new Fbr_DigitalInvoicing();
                ApiResponse response = null;

                await Task.Run(() =>
                {
                    bool isRunningInVisualStudio =  Debugger.IsAttached;
                    if (LoginInfo.EnableSandBox && !isRunningInVisualStudio)
                    {
                        response = api.SendModelToApi(invoiceModel, LoginInfo.FbrTokenProduction, true,true);
                    }
                    else
                    {
                        response = api.SendModelToApi(invoiceModel, LoginInfo.FbrTokenSandBox,true);
                    }

                    
                });

                if (response == null || response.validationResponse == null)
                {
                    row.DefaultCellStyle.BackColor = Color.OrangeRed;
                    MessageBox.Show($"Row {i + 1} failed: Null response from FBR.", "API Error", MessageBoxButtons.OK, MessageBoxIcon.Error);
                    return;
                }

                var vr = response.validationResponse;

                if (vr.statusCode != "00")
                {
                    row.DefaultCellStyle.BackColor = Color.OrangeRed;

                    if (string.IsNullOrEmpty(vr.error))
                    {
                        if (vr.invoiceStatuses.Count > 0)
                        {
                            MessageBox.Show($"Row {i + 1} FBR Error: {vr.invoiceStatuses[0].error}", "API Rejection", MessageBoxButtons.OK, MessageBoxIcon.Error);
                        }
                    }
                    else
                    {
                        MessageBox.Show($"Row {i + 1} FBR Error: {vr.error}", "API Rejection", MessageBoxButtons.OK, MessageBoxIcon.Error);
                    }
                    return;
                }

                // ✅ Success
                row.DefaultCellStyle.BackColor = Color.LightGreen;
                row.Cells["FBRInvoiceNumber"].Value = response.invoiceNumber ?? "";
            }

            MessageBox.Show("All rows validated and submitted successfully.", "Done", MessageBoxButtons.OK, MessageBoxIcon.Information);
        }

        private DataTable GetGridDataWithFBRNumber()
        {
            DataTable dt = new DataTable();

            // Create columns dynamically from grid
            foreach (DataGridViewColumn col in FrbInvGrid.Columns)
            {
                dt.Columns.Add(col.Name, typeof(string)); // or typeof(object) if mixed types
            }

            // Fill rows
            foreach (DataGridViewRow gridRow in FrbInvGrid.Rows)
            {
                if (!gridRow.IsNewRow)
                {
                    DataRow row = dt.NewRow();

                    foreach (DataGridViewCell cell in gridRow.Cells)
                    {
                        row[cell.OwningColumn.Name] = cell.Value ?? DBNull.Value;
                    }

                    dt.Rows.Add(row);
                }
            }

            return dt;
        }




        private async void btnSubmitOld_Click(object sender, EventArgs e)
        {
            btnSubmit.Enabled = false;
            progressBar1.Visible = true;
            lblProgress.Visible = true;
            progressBar1.Value = 0;

            try
            {
                var result = FbrLibraryClasses.ConvertGridToFbrInvoices(this.FrbInvGrid);
                int total = result.Count;

                if (total == 0)
                {
                    MessageBox.Show("No invoices found to submit.");
                    return;
                }

                if (!FrbInvGrid.Columns.Contains("FBRInvoiceNumber"))
                {
                    FrbInvGrid.Columns.Add("FBRInvoiceNumber", "FBR Invoice Number");
                }
                progressBar1.Maximum = total;

                await Task.Run(() =>
                {
                    var obj = new Fbr_DigitalInvoicing();
                    int current = 0;

                    for (int i = 0; i < result.Count; i++)
                    {
                        var data = result[i];
                        ApiResponse response = null;

                        try
                        {
                            response = obj.SendModelToApi(data, "f6f6a509-2839-3cf1-ad92-fb0f7ab6d06a");

                            Invoke(new Action(() =>
                            {
                                var row = FrbInvGrid.Rows[i];

                                if (response != null && response.validationResponse?.statusCode == "00")
                                {
                                    // If column doesn't exist, create it (once)
                                    if (!FrbInvGrid.Columns.Contains("FbrInvoiceNumber"))
                                    {
                                        FrbInvGrid.Columns.Add("FbrInvoiceNumber", "FBR Invoice #");
                                    }

                                    row.Cells["FbrInvoiceNumber"].Value = response.invoiceNumber ?? "";
                                    row.DefaultCellStyle.BackColor = Color.LightGreen;
                                }
                                else
                                {
                                    row.DefaultCellStyle.BackColor = Color.OrangeRed;
                                    string err = response?.validationResponse?.error ?? "Unknown error";
                                    MessageBox.Show($"Invoice  failed:\n{err}", "API Submission Failed", MessageBoxButtons.OK, MessageBoxIcon.Error);
                                }

                                progressBar1.Value = ++current;
                            }));
                        }
                        catch (Exception ex)
                        {
                            Invoke(new Action(() =>
                            {
                                MessageBox.Show($"Error in invoice :\n{ex.Message}");
                                progressBar1.Value = ++current;
                            }));
                        }
                    }
                });

                MessageBox.Show("All invoices submitted successfully.");

                // Show export button at the end
                btnExportExcel.Visible = true;
            }
            catch (Exception ex)
            {
                MessageBox.Show($"An error occurred: {ex.Message}", "Submission Failed", MessageBoxButtons.OK, MessageBoxIcon.Error);
            }
            finally
            {
                progressBar1.Visible = false;
                lblProgress.Visible = false;
                btnSubmit.Enabled = true;
            }
        }
