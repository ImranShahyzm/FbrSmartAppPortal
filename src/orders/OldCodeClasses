  public ActionResult PunchInvoicesToFbr(string SaleIDs, byte SalesApproval)
  {
      try
      {

          if (string.IsNullOrWhiteSpace(SaleIDs))
          {
              return Content(JsonConvert.SerializeObject(new
              {
                  Message = "No SaleIDs provided."
              }, Formatting.None, new JsonSerializerSettings { ReferenceLoopHandling = ReferenceLoopHandling.Ignore }), "application/json");
          }





          var FBRQImagePath = Server.MapPath("~/AppFiles/FbrQrDigital/");
          string filePath = Server.MapPath("~/AppFiles/FBRInvoiceLogFallback.txt");
          var FbrQrDigitalPath = "/AppFiles/FbrQrDigital/";

          data_SaleInfoModel model = new data_SaleInfoModel
          {
              SalesApproval = SalesApproval
          };
          model.LoadCompanyAnduser();

          var saleIdList = SaleIDs.Split(',')
                                  .Select(id => id.Trim())
                                  .Where(id => int.TryParse(id, out _))
                                  .Select(int.Parse)
                                  .Distinct()
                                  .ToList();
          if (!saleIdList.Any())
          {
              return Content(JsonConvert.SerializeObject(new
              {
                  Message = "Invalid SaleIDs provided."
              }, Formatting.None, new JsonSerializerSettings { ReferenceLoopHandling = ReferenceLoopHandling.Ignore }), "application/json");
          }

          foreach (var saleId in saleIdList)
          {
              
          if (System.IO.File.Exists(filePath))
          {
              string[] lines = System.IO.File.ReadAllLines(filePath);
              foreach (string line in lines)
              {
                  string[] parts = line.Split(new[] { ',' }, 8);
                  if (parts.Length == 8 && int.TryParse(parts[1], out int saleID) && saleID == saleId)
                  {
                      string existingFbrInvoiceNumber = parts[4];
                      if (!string.IsNullOrEmpty(existingFbrInvoiceNumber))
                      {
                          throw new Exception($"An FBRInvoiceNumber ({existingFbrInvoiceNumber}) already exists for SaleID {saleId}. Please contact the developer.");
                      }
                  }
              }
          }
          }

          var results = new List<object>();

          using (SqlConnection conn = new SqlConnection(GStatic.Connection()))
          {
              conn.Open();

              foreach (var saleId in saleIdList)
              {


                 

                  using (SqlTransaction transaction = conn.BeginTransaction())
                  {
                      try
                      {
                          if (!model.AcquireLock(saleId, conn, transaction))
                          {

                              results.Add(new
                              {
                                  SaleID = saleId,
                                  Status = "Skipped",
                                  Message = "SaleID is currently being processed by another request."
                              });
                              continue;
                          }

                          // Process the invoice since lock is acquired
                          string result = model.PunchInvoicesToFBr(
                              MasterID: saleId,
                              UserID: model.UserID,
                              CompanyID: model.CompanyID,
                              IsManufacturerFBR: true,
                              FBRInvoiceNumber: "",
                              FBRQImagePath: FBRQImagePath,
                              FbrQrDigitalPath: FbrQrDigitalPath,
                              connection:conn,
                              transaction:transaction,
                              filePath: filePath
                          );

                          // Commit the transaction if successful
                          transaction.Commit();

                          results.Add(new
                          {
                              SaleID = saleId,
                              Status = "Success",
                              Message = result
                          });
                      }
                      catch (Exception ex)
                      {
                          // Roll back the transaction on error
                          transaction.Rollback();
                          results.Add(new
                          {
                              SaleID = saleId,
                              Status = "Error",
                              Message = $"Error processing SaleID {saleId}: {ex.Message}"
                          });
                          var jsonResponse2 = JsonConvert.SerializeObject(new
                          {
                              Message = $"Error processing SaleID {saleId}: {ex.Message}",
                              Results = results
                          }, Formatting.None, new JsonSerializerSettings { ReferenceLoopHandling = ReferenceLoopHandling.Ignore });
                          return Content(jsonResponse2, "application/json");

                      }
                  }
              }
          }

          // Serialize the results to JSON
          var jsonResponse = JsonConvert.SerializeObject(new
          {
              Message = "Processing completed for all SaleIDs.",
              Results = results
          }, Formatting.None, new JsonSerializerSettings { ReferenceLoopHandling = ReferenceLoopHandling.Ignore });
          return Content(jsonResponse, "application/json");
      }
      catch (Exception ex)
      {
          var jsonResponse = JsonConvert.SerializeObject(new
          {
              Message = $"Error processing SaleIDs: {ex.Message}",
              Results = new List<object>()
          }, Formatting.None, new JsonSerializerSettings { ReferenceLoopHandling = ReferenceLoopHandling.Ignore });
          return Content(jsonResponse, "application/json");
      }
  }


